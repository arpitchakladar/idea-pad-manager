WarningsAsErrors: ''
FormatStyle: 'file'
InheritParentConfig: true
HeaderFilterRegex: '.*/src/.*'
Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  modernize-*,
  readability-*,
  misc-*

CheckOptions:
# --- CONST CORRECTNESS ---
  - key:             misc-const-correctness.AnalyzeValues
    value:           'true'
  - key:             misc-const-correctness.AnalyzeReferences
    value:           'true'
  - key:             misc-const-correctness.WarnPointersAsValues
    value:           'true'
  # misc-const-correctness settings
  - key:             misc-const-correctness.AnalyzeValues
    value:           'true'
  - key:             misc-const-correctness.WarnPointersAsValues
    value:           'true'
  - key:             misc-const-correctness.TransformToConstexpr
    value:           'true'
  # Lower this! Default is often 3. 
  # This allows 'auto X = 5' to become 'const auto X = 5'
  - key:             misc-const-correctness.MinVariableDeclarationLength
    value:           '1'
  # This automatically turns 'const' into 'constexpr' where possible
  - key:             misc-const-correctness.TransformToConstexpr
    value:           'true'

  # --- AUTO QUALIFICATION ---
  # Ensures 'const auto&' or 'const auto*' style
  - key:             readability-qualified-auto.AddConstToQualified
    value:           'true'

  # --- TYPES: PascalCase ---
  - key:             readability-identifier-naming.ClassCase
    value:           CamelCase
  - key:             readability-identifier-naming.StructCase
    value:           CamelCase
  - key:             readability-identifier-naming.EnumCase
    value:           CamelCase
  - key:             readability-identifier-naming.TypeAliasCase
    value:           CamelCase
  - key:             readability-identifier-naming.TemplateParameterCase
    value:           CamelCase

  # --- FUNCTIONS: camelCase (lowerCamelCase) ---
  - key:             readability-identifier-naming.FunctionCase
    value:           lowerCamelCase
  - key:             readability-identifier-naming.MethodCase
    value:           lowerCamelCase

  # --- VARIABLES: PascalCase (The "Noun" in AAA) ---
  - key:             readability-identifier-naming.VariableCase
    value:           CamelCase
  - key:             readability-identifier-naming.ParameterCase
    value:           CamelCase
  - key:             readability-identifier-naming.LocalVariableCase
    value:           CamelCase
  - key:             readability-identifier-naming.GlobalVariableCase
    value:           CamelCase
  - key:             readability-identifier-length.MinimumVariableNameLength
    value:           '1'
  - key:             readability-identifier-length.MinimumParameterNameLength
    value:           '1'
  - key:             readability-identifier-length.MinimumLoopCounterNameLength
    value:           '1'

  # --- MEMBERS: m_PascalCase ---
  - key:             readability-identifier-naming.MemberCase
    value:           CamelCase
  - key:             readability-identifier-naming.MemberPrefix
    value:           'm_'

  # --- CONSTANTS: k_PascalCase (Google-style hybrid) ---
  - key:             readability-identifier-naming.ConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.GlobalConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.GlobalConstantPrefix
    value:           'k_'
  - key:             readability-identifier-naming.StaticConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.StaticConstantPrefix
    value:           'k_'

  # --- NAMESPACES: snake_case ---
  - key:             readability-identifier-naming.NamespaceCase
    value:           lower_case

  # --- MODERNIZATION (Strict AAA) ---
  - key:             modernize-use-trailing-return-type.MinTypeComplexity
    value:           '0'
  - key:             modernize-use-auto.MinTypeNameLength
    value:           '0'
  - key:             modernize-use-auto.RemoveStars
    value:           'true'
  - key:             modernize-return-braced-init-list.MinTypeNameLength
    value:           '0'

  # --- HEADER GUARDS ---
  - key:             modernize-replace-header-guard.HeaderGuardStyle
    value:           'HeaderGuard'
