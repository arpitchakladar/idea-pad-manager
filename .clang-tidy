WarningsAsErrors: ''
FormatStyle: 'LLVM'
InheritParentConfig: true
HeaderFilterRegex: '.*/src/.*'
Checks: >
  clang-analyzer-*,
  bugprone-narrowing-conversions,
  cppcoreguidelines-narrowing-conversions,
  bugprone-*,
  performance-*,
  modernize-*,
  readability-*,
  misc-*,
  cppcoreguidelines-*,
  -modernize-use-trailing-return-type,
  -modernize-return-braced-init-list,
  -bugprone-easily-swappable-parameters,
  -readability-convert-member-functions-to-static

CheckOptions:
# --- CONST CORRECTNESS ---
  - key:             misc-const-correctness.AnalyzeValues
    value:           'true'
  - key:             misc-const-correctness.AnalyzeReferences
    value:           'true'
  - key:             misc-const-correctness.WarnPointersAsValues
    value:           'true'
  - key:             misc-const-correctness.TransformToConstexpr
    value:           'true'
  - key:             misc-const-correctness.MinVariableDeclarationLength
    value:           '1'
  - key:             readability-qualified-auto.AddConstToQualified
    value:           'true'

# --- EXPLICIT CONSTRUCTORS ---
  - key:             google-explicit-constructor.Mode
    value:           'exceptions'
  - key:             readability-explicit-simple2.AllowShortLambdasOnSingleLine
    value:           'true'

# --- TYPES: PascalCase ---
  - key:             readability-identifier-naming.ClassCase
    value:           CamelCase
  - key:             readability-identifier-naming.StructCase
    value:           CamelCase
  - key:             readability-identifier-naming.EnumCase
    value:           CamelCase
  - key:             readability-identifier-naming.EnumConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.TypeAliasCase
    value:           CamelCase
  - key:             readability-identifier-naming.TemplateParameterCase
    value:           CamelCase
  - key:             readability-identifier-naming.TypedefCase
    value:           CamelCase
  - key:             readability-identifier-naming.TypeTemplateParameterCase
    value:           CamelCase

# --- FUNCTIONS: camelCase ---
  - key:             readability-identifier-naming.FunctionCase
    value:           camelBack
  - key:             readability-identifier-naming.MethodCase
    value:           camelBack

# --- VARIABLES: PascalCase ---
  - key:             readability-identifier-naming.VariableCase
    value:           CamelCase
  - key:             readability-identifier-naming.ParameterCase
    value:           CamelCase
  - key:             readability-identifier-naming.LocalVariableCase
    value:           CamelCase
  - key:             readability-identifier-naming.GlobalVariableCase
    value:           CamelCase
  - key:             readability-identifier-length.MinimumVariableNameLength
    value:           '1'
  - key:             readability-identifier-length.MinimumParameterNameLength
    value:           '1'
  - key:             readability-identifier-length.MinimumLoopCounterNameLength
    value:           '1'

# --- MEMBERS: m_PascalCase ---
  - key:             readability-identifier-naming.PrivateMemberCase
    value:           CamelCase
  - key:             readability-identifier-naming.PrivateMemberPrefix
    value:           'm_'
  - key:             readability-identifier-naming.ProtectedMemberCase
    value:           CamelCase
  - key:             readability-identifier-naming.ProtectedMemberPrefix
    value:           'm_'
  - key:             readability-identifier-naming.MemberCase
    value:           CamelCase
  - key:             readability-identifier-naming.MemberPrefix
    value:           'm_'
  - key:             readability-identifier-naming.PublicMemberCase
    value:           CamelCase
  - key:             readability-identifier-naming.PublicMemberPrefix
    value:           ''

# --- LOCAL CONSTEXPR: k_PascalCase (function-local) ---
  - key:             readability-identifier-naming.ConstexprVariableCase
    value:           CamelCase
  - key:             readability-identifier-naming.ConstexprVariablePrefix
    value:           'k_'

# --- STATIC CONSTANTS: g_PascalCase (class/namespace level) ---
  - key:             readability-identifier-naming.StaticConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.StaticConstantPrefix
    value:           'g_'
  - key:             readability-identifier-naming.StaticConstVariableCase
    value:           CamelCase
  - key:             readability-identifier-naming.StaticConstVariablePrefix
    value:           'g_'
  - key:             readability-identifier-naming.MacroCase
    value:           UPPER_CASE

# --- GLOBAL CONSTANTS: g_PascalCase ---
  - key:             readability-identifier-naming.GlobalConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.GlobalConstantPrefix
    value:           'g_'
  - key:             readability-identifier-naming.NamespaceConstantCase
    value:           CamelCase
  - key:             readability-identifier-naming.NamespaceConstantPrefix
    value:           'g_'

# --- NAMESPACES: lower_case ---
  - key:             readability-identifier-naming.NamespaceCase
    value:           lower_case
  - key:             readability-identifier-naming.UsingAliasCase
    value:           CamelCase

# --- ENUMS ---
  - key:             readability-identifier-naming.EnumClassCase
    value:           CamelCase

# --- MODERNIZATION ---
  - key:             modernize-use-auto.MinTypeNameLength
    value:           '0'
  - key:             modernize-use-auto.RemoveStars
    value:           'true'
  - key:             modernize-use-nullptr.Nullability
    value:           'true'
  - key:             modernize-use-emplace.Threshold
    value:           '2'
  - key:             modernize-pass-by-value.MaxThreshold
    value:           '0'
  - key:             modernize-replace-auto-ptr.ShouldReplaceAutoPtr
    value:           'true'

# --- HEADER GUARDS ---
  - key:             modernize-replace-header-guard.HeaderGuardStyle
    value:           'HeaderGuard'

# --- REDUNDANCY & CLARITY ---
  - key:             readability-redundant-string-init.StringNames
    value:           ''
  - key:             readability-simplify-boolean-expr.ChainedConditional
    value:           'true'

# --- NARROWING CONVERSIONS ---
  - key:             cppcoreguidelines-narrowing-conversions.WarnOnTypeNarrowing
    value:           'true'
  - key:             cppcoreguidelines-narrowing-conversions.WarnOnMagicNarrowing
    value:           'true'

# --- FUNCTION STYLE ---
  - key:             readability-function-size.MaxFunctionLines
    value:           '50'
  - key:             readability-function-cognitive-complexity.MaxFunctionComplexity
    value:          '15'
